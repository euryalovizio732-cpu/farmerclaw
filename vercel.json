{
  "version": 2,
  "functions": {
    "backend/app/main.py": {
      "maxDuration": 60
    }
  },
  "builds": [
    {
      "src": "backend/app/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/app/main.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "frontend/assets/$1"
    },
    {
      "src": "/favicon.svg",
      "dest": "frontend/favicon.svg"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/index.html"
    }
  ]
}
